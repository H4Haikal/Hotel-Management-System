<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>LogoutServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>addReservation</servlet-name>
        <servlet-class>hotel.management.AddReservation</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AvailableRoomServlet</servlet-name>
        <servlet-class>AvailableRoomServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>addReservation</servlet-name>
        <url-pattern>/addReservation</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AvailableRoomServlet</servlet-name>
        <url-pattern>/AvailableRoomServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
